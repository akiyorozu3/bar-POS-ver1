# Firebase の設定値をここに入れてください
# Firebase Console > プロジェクト設定 > マイアプリ からコピーできます
# このファイルを .env にリネームして使用してください

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# バック率（0.30 = 30%）
VITE_BACK_RATE=0.30

# ── ログイン設定 ─────────────────────────────
# ログインIDを内部でメールアドレスに変換する際の固定ドメイン（実在しなくてよい）
# 例: staff → staff@bar-pos.local
VITE_AUTH_ID_DOMAIN=bar-pos.local

# オーナー扱いにするログインID（これ以外はスタッフ扱い）
# Firestoreルールの owner@<ドメイン> と一致させること
VITE_OWNER_ID=owner
