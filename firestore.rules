rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ログイン済みか
    function isAuthed() {
      return request.auth != null;
    }

    // オーナーか（ログインIDが owner のアカウント）
    // ※ VITE_OWNER_ID / VITE_AUTH_ID_DOMAIN を変えた場合はここも合わせること
    function isOwner() {
      return isAuthed() && request.auth.token.email == 'owner@bar-pos.local';
    }

    // マネージャーか（オーナーより弱く、スタッフより強い）
    // ※ VITE_MANAGER_ID を変えた場合はここも合わせること
    function isManager() {
      return isAuthed() && request.auth.token.email == 'manager@bar-pos.local';
    }

    // 売上管理を見られる権限（オーナー or マネージャー）
    function canSales() {
      return isOwner() || isManager();
    }

    // メニュー：ログイン済みは閲覧可 / 追加・編集・削除はオーナーのみ
    match /menus/{id} {
      allow read: if isAuthed();
      allow write: if isOwner();
    }

    // キャスト：ログイン済みは閲覧可（注文画面の担当選択に必要） / 編集はオーナーのみ
    match /casts/{id} {
      allow read: if isAuthed();
      allow write: if isOwner();
    }

    // 席・未会計の注文：ログイン済みなら読み書き可（スタッフが注文を取るため）
    match /tables/{id} {
      allow read, write: if isAuthed();
    }

    // レジ締め：ログイン済みは閲覧可（締め済み判定に必要） / 締め・解除はオーナーのみ
    match /closures/{id} {
      allow read: if isAuthed();
      allow write: if isOwner();
    }

    // 打刻：ログイン済みは閲覧・作成可（将来スタッフにも開放できるように） / 修正・削除はオーナーのみ
    match /punches/{id} {
      allow read, create: if isAuthed();
      allow update, delete: if isOwner();
    }

    // 日払い/大入：オーナー・マネージャー（追加/削除まで可）
    match /payouts/{id} {
      allow read, write: if canSales();
    }

    // 経費・固定費：オーナー・マネージャー（追加/削除まで可）
    match /expenses/{id} {
      allow read, write: if canSales();
    }
    match /recurringExpenses/{id} {
      allow read, write: if canSales();
    }

    // 手数料設定：ログイン済みは閲覧可（会計計算に必要） / 変更はオーナーのみ
    match /settings/{id} {
      allow read: if isAuthed();
      allow write: if isOwner();
    }

    // 取引（売上）：スタッフは「会計の確定（作成）」のみ可能。
    // 閲覧はオーナー・マネージャー。修正・削除はオーナーのみ（マネージャーは閲覧専用）。
    match /transactions/{id} {
      allow create: if isAuthed();
      allow read: if canSales();
      allow update, delete: if isOwner();
    }
  }
}
